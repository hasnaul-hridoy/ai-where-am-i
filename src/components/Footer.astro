---
/**
 * Footer.astro
 * Full-width footer with author details and prototype notice.
 */
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-left">
      <span class="footer-title"><a href="/">AI: Where Am I?</a></span>
      <span class="footer-subtitle">A Non-Technical Guide to Understanding AI Across Fields</span>
      <span class="footer-prototype">? Prototype — work in progress. Content and design are subject to change.</span>
    </div>
    <div class="footer-right">
      <span class="footer-author">Hasnaul Hridoy</span>
      <span class="footer-role">Researcher &amp; Author</span>
      <a class="footer-github" href="https://github.com/hasnaul-hridoy/ai-where-am-i" target="_blank" rel="noopener noreferrer">github.com/hasnaul-hridoy/ai-where-am-i</a>
    </div>
  </div>
  <div class="footer-bottom">
    <span>2026 &copy; Hasnaul Hridoy &mdash; All rights reserved.</span>
  </div>
</footer>

<style>
  .site-footer { background: var(--color-header); color: rgba(255,255,255,0.75); margin-top: 3rem; border-top: 1px solid rgba(255,255,255,0.1); }
  .footer-inner { max-width: 900px; margin: 0 auto; padding: 2.5rem 2rem 1.5rem; display: flex; gap: 3rem; justify-content: space-between; flex-wrap: wrap; }
  .footer-left, .footer-right { display: flex; flex-direction: column; gap: 0.4rem; }
  .footer-title a { font-family: var(--font-heading); font-size: 1.1rem; color: #fff; text-decoration: none; }
  .footer-title a:hover { text-decoration: underline; }
  .footer-subtitle { font-size: 0.82rem; color: rgba(255,255,255,0.55); }
  .footer-prototype { margin-top: 0.5rem; font-size: 0.78rem; color: rgba(255,220,100,0.85); font-style: italic; }
  .footer-author { font-family: var(--font-heading); font-size: 1rem; color: #fff; }
  .footer-role { font-size: 0.82rem; color: rgba(255,255,255,0.55); }
  .footer-github { font-size: 0.78rem; color: rgba(255,255,255,0.45); text-decoration: none; font-family: monospace; }
  .footer-github:hover { color: rgba(255,255,255,0.8); text-decoration: underline; }
  .footer-bottom { border-top: 1px solid rgba(255,255,255,0.08); text-align: center; padding: 0.9rem 2rem; font-size: 0.76rem; color: rgba(255,255,255,0.35); }
</style>
