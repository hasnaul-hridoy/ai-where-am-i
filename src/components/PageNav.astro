---
/**
 * PageNav.astro
 * Previous / Next chapter navigation links at the bottom of each chapter.
 */
import type { Chapter } from '../data/chapters';

interface Props {
  prev: Chapter | null;
  next: Chapter | null;
}

const { prev, next } = Astro.props;
---

<nav class="page-nav" aria-label="Chapter navigation">

  {prev ? (
    <a href={`/chapters/${prev.slug}`} class="page-nav__link page-nav__link--prev">
      <span class="page-nav__direction">Previous</span>
      <span class="page-nav__title">{prev.title}</span>
    </a>
  ) : (
    <div /> <!-- Empty placeholder to keep next button right-aligned -->
  )}

  {next && (
    <a href={`/chapters/${next.slug}`} class="page-nav__link page-nav__link--next">
      <span class="page-nav__direction">Next Chapter</span>
      <span class="page-nav__title">{next.title}</span>
    </a>
  )}

</nav>
