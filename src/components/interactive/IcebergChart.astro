---
/**
 * IcebergChart.astro
 * D3 force-directed bubble chart showing consumer AI (above waterline)
 * vs. research AI fields (below waterline).
 *
 * Pattern reference: D3 force simulation with collision detection
 * https://d3-graph-gallery.com/network.html
 *
 * client:visible — only hydrates when this element enters the viewport
 */
---

<div class="iceberg-chart-container" style="position: relative;">
  <div id="iceberg-viz" style="width: 100%; min-height: 640px;"></div>
  <div class="d3-tooltip" id="iceberg-tooltip"></div>
</div>

<script>
  // Lazy-load D3 only when this component is visible
  const container = document.getElementById('iceberg-viz');
  if (!container) throw new Error('IcebergChart: container not found');

  const observer = new IntersectionObserver(async (entries) => {
    if (!entries[0].isIntersecting) return;
    observer.disconnect();

    // Dynamic import of D3 (tree-shaken)
    const d3 = await import('https://cdn.jsdelivr.net/npm/d3@7/+esm');
    drawChart(d3);
  }, { threshold: 0.2 });

  observer.observe(container);

  function drawChart(d3: any) {
    // Clear any previous render (useful during hot-reload in dev)
    container!.innerHTML = '';

    const tooltip = document.getElementById('iceberg-tooltip')!;
    const w = container!.clientWidth || 700;
    const h = 640;
    const waterY = h * 0.24; // Waterline position

    // ---- Data ----
    const aboveData = [
      { name: 'Chatbots',          r: 36, detail: 'ChatGPT, Claude, Gemini — the AI most people interact with daily.' },
      { name: 'Image\nGenerators', r: 34, detail: 'DALL-E, Midjourney, Stable Diffusion — text to images.' },
      { name: 'Voice\nAssistants', r: 32, detail: 'Siri, Alexa, Google Assistant — voice-based AI on every phone.' },
    ];

    const belowData = [
      { name: 'Drug\nDiscovery',    r: 48, color: '#D4612C', detail: 'Halicin found from 107M compounds via a novel mechanism.' },
      { name: 'Protein\nFolding',   r: 52, color: '#2B7A6F', detail: 'AlphaFold predicted 200M+ protein structures — a 50-year challenge.' },
      { name: 'Weather\nPrediction',r: 44, color: '#4A6A80', detail: 'GraphCast: 10-day forecast in under a minute on a single chip.' },
      { name: 'Materials\nScience', r: 50, color: '#6C4EA3', detail: 'GNoME discovered 2.2M stable crystals — 8x the known catalogue.' },
      { name: 'Genomics',           r: 40, color: '#2B7A6F', detail: 'AI maps non-coding DNA and identifies disease-causing variants.' },
      { name: 'Fusion\nEnergy',     r: 36, color: '#B8942A', detail: 'RL controllers maintain plasma in tokamak fusion reactors.' },
      { name: 'Conservation',       r: 42, color: '#3D7A4A', detail: 'Satellite imagery tracking deforestation and wildlife at scale.' },
      { name: 'Legal\nAnalysis',    r: 32, color: '#C47A50', detail: 'Case outcome prediction, contract review, regulatory risk.' },
      { name: 'Ancient\nLanguages', r: 40, color: '#A8887A', detail: 'Reconstructed 2,600-year-old Akkadian tablets.' },
    ];

    // ---- SVG setup ----
    const svg = d3.select(container)
      .append('svg')
      .attr('width', w)
      .attr('height', h)
      .style('display', 'block');

    // Water gradient definition
    const defs = svg.append('defs');
    const waterGradient = defs.append('linearGradient')
      .attr('id', 'waterGrad')
      .attr('x1', '0%').attr('y1', '0%')
      .attr('x2', '0%').attr('y2', '100%');
    waterGradient.append('stop').attr('offset', '0%')  .attr('stop-color', '#DDE4D8').attr('stop-opacity', 0.4);
    waterGradient.append('stop').attr('offset', '100%').attr('stop-color', '#B0C4A8').attr('stop-opacity', 0.6);

    // Background zones
    svg.append('rect').attr('width', w).attr('height', waterY).attr('fill', '#FAFBF6');
    svg.append('rect').attr('y', waterY).attr('width', w).attr('height', h - waterY).attr('fill', 'url(#waterGrad)');

    // Waterline
    svg.append('line')
      .attr('x1', 0).attr('y1', waterY).attr('x2', w).attr('y2', waterY)
      .attr('stroke', '#5A7A58').attr('stroke-width', 1.5)
      .attr('stroke-dasharray', '8,4').attr('opacity', 0.4);

    // Zone labels
    svg.append('text').attr('x', 16).attr('y', waterY - 8).attr('fill', '#8A9A85').attr('font-size', 10).attr('font-weight', 600).attr('letter-spacing', '0.08em').text('WHAT PEOPLE SEE');
    svg.append('text').attr('x', 16).attr('y', waterY + 18).attr('fill', '#8A9A85').attr('font-size', 10).attr('font-weight', 600).attr('letter-spacing', '0.08em').text('WHAT AI ACTUALLY DOES');

    // ---- Above-waterline bubbles ----
    const aSim = d3.forceSimulation(aboveData)
      .force('x', d3.forceX(w / 2).strength(0.12))
      .force('y', d3.forceY(waterY / 2).strength(0.2))
      .force('collide', d3.forceCollide((d: any) => d.r + 10))
      .stop();

    for (let i = 0; i < 200; i++) aSim.tick();

    // Clamp to above-water zone
    aboveData.forEach((d: any) => {
      d.x = Math.max(d.r + 4, Math.min(w - d.r - 4, d.x));
      d.y = Math.max(d.r + 4, Math.min(waterY - d.r - 4, d.y));
    });

    const aGroups = svg.selectAll('.above-bubble').data(aboveData).enter().append('g');

    aGroups.append('circle')
      .attr('cx', (d: any) => d.x)
      .attr('cy', (d: any) => d.y)
      .attr('r', 0)
      .attr('fill', '#DDE4D8')
      .attr('stroke', '#5A7A58')
      .attr('stroke-width', 1.5)
      .attr('cursor', 'default')
      .on('mouseenter', function(event: MouseEvent, d: any) {
        d3.select(this).transition().duration(200).attr('r', d.r + 4);
        showTooltip(event, `${d.name.replace('\n', ' ')}: ${d.detail}`);
      })
      .on('mouseleave', function(_: MouseEvent, d: any) {
        d3.select(this).transition().duration(200).attr('r', d.r);
        hideTooltip();
      })
      .transition()
      .delay((_: any, i: number) => i * 100)
      .duration(600)
      .ease(d3.easeCubicOut)
      .attr('r', (d: any) => d.r);

    aGroups.each(function(d: any) {
      addLabel(d3.select(this), d, 12, '#1A2818');
    });

    // ---- Below-waterline bubbles ----
    belowData.forEach((d: any) => {
      d.x = w / 2 + (Math.random() - 0.5) * w * 0.6;
      d.y = waterY + 40 + Math.random() * (h - waterY - 80);
    });

    const bSim = d3.forceSimulation(belowData)
      .force('x', d3.forceX(w / 2).strength(0.06))
      .force('y', d3.forceY(waterY + (h - waterY) / 2 + 10).strength(0.08))
      .force('collide', d3.forceCollide((d: any) => d.r + 12))
      .stop();

    for (let i = 0; i < 300; i++) bSim.tick();

    // Clamp to below-water zone
    belowData.forEach((d: any) => {
      d.x = Math.max(d.r + 4, Math.min(w - d.r - 4, d.x));
      d.y = Math.max(waterY + d.r + 8, Math.min(h - d.r - 4, d.y));
    });

    const bGroups = svg.selectAll('.below-bubble').data(belowData).enter().append('g');

    bGroups.append('circle')
      .attr('cx', (d: any) => d.x)
      .attr('cy', (d: any) => d.y)
      .attr('r', 0)
      .attr('fill', (d: any) => d.color)
      .attr('fill-opacity', 0.85)
      .attr('stroke', '#fff')
      .attr('stroke-width', 1.5)
      .attr('stroke-opacity', 0.3)
      .attr('cursor', 'default')
      .on('mouseenter', function(event: MouseEvent, d: any) {
        d3.select(this).transition().duration(200).attr('r', d.r + 5).attr('fill-opacity', 1);
        showTooltip(event, `${d.name.replace('\n', ' ')}: ${d.detail}`);
      })
      .on('mouseleave', function(_: MouseEvent, d: any) {
        d3.select(this).transition().duration(200).attr('r', d.r).attr('fill-opacity', 0.85);
        hideTooltip();
      })
      .transition()
      .delay((_: any, i: number) => 300 + i * 80)
      .duration(700)
      .ease(d3.easeBackOut.overshoot(0.8))
      .attr('r', (d: any) => d.r);

    bGroups.each(function(d: any, i: number) {
      const g = d3.select(this);
      setTimeout(() => addLabel(g, d, d.r > 40 ? 13 : 11, '#1A2818'), 600 + i * 80);
    });

    // ---- Helpers ----

    function addLabel(g: any, d: any, size: number, fill: string) {
      const lines = d.name.split('\n');
      const text = g.append('text')
        .attr('x', d.x).attr('y', d.y)
        .attr('text-anchor', 'middle')
        .attr('font-size', size)
        .attr('font-weight', 600)
        .attr('fill', fill)
        .attr('pointer-events', 'none')
        .style('font-family', 'Inter, sans-serif');

      lines.forEach((line: string, i: number) => {
        text.append('tspan')
          .attr('x', d.x)
          .attr('dy', i === 0 ? `${-0.6 * (lines.length - 1)}em` : '1.15em')
          .text(line);
      });
    }

    function showTooltip(event: MouseEvent, text: string) {
      const rect = container!.getBoundingClientRect();
      tooltip.textContent = text;
      tooltip.classList.add('is-visible');
      let x = event.clientX - rect.left + 12;
      let y = event.clientY - rect.top - 10;
      if (x + 220 > rect.width) x -= 240;
      tooltip.style.left = `${x}px`;
      tooltip.style.top  = `${y}px`;
    }

    function hideTooltip() {
      tooltip.classList.remove('is-visible');
    }

    // Re-draw on resize (debounced)
    let resizeTimer: ReturnType<typeof setTimeout>;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => drawChart(d3), 250);
    });
  }
</script>
