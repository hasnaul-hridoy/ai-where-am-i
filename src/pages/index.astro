---
/**
 * index.astro
 * Landing page — introduces the project and links to Chapter 1.
 */
import '../styles/global.css';
import '../styles/layout.css';
import '../styles/components.css';
import Footer from '../components/Footer.astro';
import { chapters, parts, getChaptersByPart } from '../data/chapters';
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="AI: Where Am I? — A non-technical guide to understanding AI across scientific fields." />
  <title>AI: Where Am I?</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
</head>

<body style="background: var(--color-bg);">

  <!-- Header -->
  <header class="site-header">
    <div class="site-header__inner">
      <span class="site-header__brand">AI: Where Am I?</span>
    </div>
  </header>

  <!-- Hero -->
  <main style="max-width: 700px; margin: 80px auto; padding: 0 32px 100px; text-align: center;">

    <p style="font-family: var(--font-mono); font-size: 12px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-accent); margin-bottom: 16px;">
      A Non-Technical Guide
    </p>

    <h1 style="font-family: var(--font-display); font-size: 3.2em; color: var(--color-text); line-height: 1.1; margin-bottom: 20px;">
      AI: Where Am I?
    </h1>

    <p style="font-family: var(--font-serif); font-style: italic; font-size: 1.2em; color: var(--color-text-muted); line-height: 1.6; margin-bottom: 40px;">
      Most people think AI means chatbots.<br />This guide tells the other story.
    </p>

    <a
      href="/chapters/01-the-ai-you-think-you-know"
      style="display: inline-block; background: var(--color-accent); color: white; font-family: var(--font-sans); font-weight: 600; font-size: 15px; padding: 14px 32px; border-radius: var(--radius-md); text-decoration: none; transition: background 0.2s; letter-spacing: 0.01em;"
      onmouseover="this.style.background='var(--color-accent-hover)'"
      onmouseout="this.style.background='var(--color-accent)'"
    >
      Start Reading &rarr;
    </a>

    <!-- Chapter list -->
    <div style="margin-top: 80px; text-align: left;">
      {parts.map(part => (
        <div style="margin-bottom: 40px;">
          <h2 style="font-family: var(--font-display); font-size: 1.4em; color: var(--color-text); margin-bottom: 12px;">
            {part.label}
          </h2>
          <ul style="list-style: none; padding: 0; border-left: 2px solid var(--color-border); padding-left: 20px;">
            {getChaptersByPart(part.number).map(chapter => (
              <li style="margin-bottom: 8px;">
                {chapter.published ? (
                  <a
                    href={`/chapters/${chapter.slug}`}
                    style="font-size: 15px; color: var(--color-accent); text-decoration: none; font-weight: 500;"
                  >
                    {chapter.title}
                  </a>
                ) : (
                  <span style="font-size: 15px; color: var(--color-text-light);">
                    {chapter.title}
                  </span>
                )}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

  </main>

  <!-- Footer -->
  <Footer />

</body>
</html>
